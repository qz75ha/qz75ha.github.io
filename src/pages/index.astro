---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const recentProjects = (await getCollection('projects'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4rem 0 3rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3rem;
			}
			.hero-eyebrow {
				font-size: 0.875rem;
				font-weight: 600;
				color: var(--accent);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.75rem;
			}
			.hero h1 {
				font-size: clamp(2rem, 5vw, 3rem);
				margin-bottom: 1rem;
				line-height: 1.15;
			}
			.hero-description {
				font-size: 1.125rem;
				color: rgb(var(--gray));
				max-width: 540px;
				margin-bottom: 2rem;
				line-height: 1.7;
			}
			.hero-actions {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.6rem 1.4rem;
				border-radius: 8px;
				font-size: 0.95rem;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.15s ease;
			}
			.btn-primary {
				background: var(--accent);
				color: #fff;
			}
			.btn-primary:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.btn-secondary {
				border: 1.5px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				background: transparent;
			}
			.btn-secondary:hover {
				border-color: rgb(var(--gray));
				color: rgb(var(--black));
			}

			.section {
				margin-bottom: 3.5rem;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.75rem;
			}
			.section-header h2 {
				font-size: 1.25rem;
				margin: 0;
			}
			.section-header a {
				font-size: 0.875rem;
				font-weight: 500;
			}

			.project-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1rem;
			}
			.project-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				padding: 1.25rem;
				text-decoration: none;
				color: inherit;
				display: block;
				transition: all 0.15s ease;
			}
			.project-card:hover {
				border-color: var(--accent);
				box-shadow: var(--box-shadow);
				color: inherit;
			}
			.project-card h3 {
				font-size: 1rem;
				margin-bottom: 0.4rem;
				color: rgb(var(--black));
			}
			.project-card p {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0 0 0.75rem;
				line-height: 1.5;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.post-item {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				padding: 0.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: color 0.15s ease;
			}
			.post-item:last-child {
				border-bottom: none;
			}
			.post-item:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 0.95rem;
				font-weight: 500;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.post-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 2.5rem 0 2rem;
				}
				.project-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<p class="hero-eyebrow">Portfolio & Blog</p>
				<h1>こんにちは、<br />qz75ha です。</h1>
				<p class="hero-description">
					Web アプリケーションを作っているエンジニアです。<br />
					作ったものや学んだことを発信しています。
				</p>
				<div class="hero-actions">
					<a href="/projects" class="btn btn-primary">制作物を見る</a>
					<a href="/blog" class="btn btn-secondary">ブログを読む</a>
				</div>
			</section>

			<!-- Projects -->
			{recentProjects.length > 0 && (
				<section class="section">
					<div class="section-header">
						<h2>Projects</h2>
						<a href="/projects">すべて見る →</a>
					</div>
					<div class="project-grid">
						{recentProjects.map((project) => (
							<a href={`/projects/${project.id}/`} class="project-card">
								<h3>{project.data.title}</h3>
								<p>{project.data.description}</p>
								<div class="tags">
									{project.data.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			<!-- Blog -->
			{recentPosts.length > 0 && (
				<section class="section">
					<div class="section-header">
						<h2>Blog</h2>
						<a href="/blog">すべて見る →</a>
					</div>
					<ul class="post-list">
						{recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-item">
									<span class="post-title">{post.data.title}</span>
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
