---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="qz75ha のプロフィール・スキル・経歴" />
		<style>
			.profile {
				display: flex;
				align-items: flex-start;
				gap: 2rem;
				padding: 3rem 0 2.5rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3rem;
			}
			.avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				background: rgb(var(--gray-light));
				flex-shrink: 0;
				overflow: hidden;
			}
			.avatar img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 50%;
			}
			.profile-text h1 {
				font-size: 1.75rem;
				margin-bottom: 0.3rem;
			}
			.profile-text .role {
				font-size: 1rem;
				color: var(--accent);
				font-weight: 600;
				margin-bottom: 0.75rem;
			}
			.profile-text p {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.75;
				margin: 0;
			}

			.section {
				margin-bottom: 3rem;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.5rem;
			}
			.section-header h2 {
				font-size: 1.1rem;
				margin: 0;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				font-weight: 600;
			}

			.skill-group {
				margin-bottom: 1rem;
			}
			.skill-group-label {
				font-size: 0.8rem;
				font-weight: 600;
				color: rgb(var(--gray));
				margin-bottom: 0.4rem;
			}

			.timeline {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.timeline-item {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: 1rem;
				padding: 1rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.timeline-item:last-child {
				border-bottom: none;
			}
			.timeline-period {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				padding-top: 0.15rem;
			}
			.timeline-content h3 {
				font-size: 0.95rem;
				margin-bottom: 0.2rem;
			}
			.timeline-content p {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
			}

			.contact-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.contact-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-size: 0.95rem;
			}
			.contact-label {
				width: 80px;
				font-size: 0.8rem;
				font-weight: 600;
				color: rgb(var(--gray));
			}

			@media (max-width: 600px) {
				.profile {
					flex-direction: column;
					gap: 1.25rem;
					padding: 2rem 0 1.5rem;
				}
				.timeline-item {
					grid-template-columns: 1fr;
					gap: 0.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- プロフィールヘッダー -->
			<div class="profile">
				<div class="avatar">
					<!-- TODO: プロフィール画像を public/avatar.jpg に置いて src="/avatar.jpg" に変更 -->
					<!-- <img src="/avatar.jpg" alt="qz75ha" /> -->
				</div>
				<div class="profile-text">
					<h1>qz75ha</h1>
					<!-- TODO: 肩書きを書き換えてください -->
					<p class="role">Software Engineer</p>
					<!-- TODO: 自己紹介を書き換えてください -->
					<p>
						Web アプリケーションの設計・開発をしています。<br />
						作ったものや学んだことをブログで発信しています。
					</p>
				</div>
			</div>

			<!-- スキル -->
			<section class="section">
				<div class="section-header">
					<h2>Skills</h2>
				</div>
				<!-- TODO: 使っている技術に合わせて編集してください -->
				<div class="skill-group">
					<p class="skill-group-label">Frontend</p>
					<div class="tags">
						<span class="tag">TypeScript</span>
						<span class="tag">Next.js</span>
						<span class="tag">React</span>
						<span class="tag">Tailwind CSS</span>
						<span class="tag">Astro</span>
					</div>
				</div>
				<div class="skill-group">
					<p class="skill-group-label">Backend / Infra</p>
					<div class="tags">
						<span class="tag">Python</span>
						<span class="tag">Node.js</span>
						<span class="tag">PostgreSQL</span>
						<span class="tag">Docker</span>
					</div>
				</div>
				<div class="skill-group">
					<p class="skill-group-label">Tools</p>
					<div class="tags">
						<span class="tag">Git</span>
						<span class="tag">GitHub Actions</span>
						<span class="tag">VS Code</span>
					</div>
				</div>
			</section>

			<!-- 経歴 -->
			<section class="section">
				<div class="section-header">
					<h2>Career</h2>
				</div>
				<!-- TODO: 実際の経歴に書き換えてください -->
				<ul class="timeline">
					<li class="timeline-item">
						<span class="timeline-period">2020 – 現在</span>
						<div class="timeline-content">
							<h3>株式会社〇〇 / ソフトウェアエンジニア</h3>
							<p>Web アプリケーションの開発・運用。</p>
						</div>
					</li>
					<li class="timeline-item">
						<span class="timeline-period">2018 – 2020</span>
						<div class="timeline-content">
							<h3>株式会社△△ / エンジニア</h3>
							<p>〇〇の開発に従事。</p>
						</div>
					</li>
				</ul>
			</section>

			<!-- 連絡先 -->
			<section class="section">
				<div class="section-header">
					<h2>Contact</h2>
				</div>
				<ul class="contact-list">
					<li class="contact-item">
						<span class="contact-label">GitHub</span>
						<a href="https://github.com/qz75ha" target="_blank" rel="noopener noreferrer">
							github.com/qz75ha
						</a>
					</li>
					<!-- TODO: 公開するアカウントを追加してください -->
					<!-- <li class="contact-item">
						<span class="contact-label">X</span>
						<a href="https://x.com/..." target="_blank" rel="noopener noreferrer">@...</a>
					</li> -->
					<!-- <li class="contact-item">
						<span class="contact-label">Zenn</span>
						<a href="https://zenn.dev/..." target="_blank" rel="noopener noreferrer">zenn.dev/...</a>
					</li> -->
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
