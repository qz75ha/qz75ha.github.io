		</a>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid rgb(var(--gray-light));
		padding: 2rem 1rem;
		background: var(--surface);
	}
	.footer-nav {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		margin-bottom: 1rem;
	}
	.footer-nav a {
		font-size: 0.875rem;
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.footer-nav a:hover {
		color: rgb(var(--black));
	}
	.footer-bottom {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}
	.footer-bottom a {
		display: flex;
		align-items: center;
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.footer-bottom a:hover {
		color: rgb(var(--black));
	}
</style>
