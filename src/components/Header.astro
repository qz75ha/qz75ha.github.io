---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/qz75ha" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1rem;
		height: 56px;
	}
	.site-title {
		font-size: 1rem;
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
		letter-spacing: -0.02em;
		margin-right: auto;
	}
	.site-title:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0.25rem;
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.social-links a {
		display: flex;
		align-items: center;
		color: rgb(var(--gray));
		text-decoration: none;
		padding: 0.25rem;
		border-radius: 6px;
		transition: color 0.15s ease;
	}
	.social-links a:hover {
		color: rgb(var(--black));
	}
	@media (max-width: 480px) {
		.social-links {
			display: none;
		}
	}
</style>
